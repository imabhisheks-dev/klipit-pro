{
  "name": "klipit-pro-backend",
  "version": "1.0.0",
  "description": "Klipit Pro - Online Clipboard Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:migrate": "ts-node -P tsconfig.json ./migrations/run.ts",
    "db:seed": "ts-node -P tsconfig.json ./migrations/seed.ts",
    "db:rollback": "ts-node -P tsconfig.json ./migrations/rollback.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "clipboard",
    "file-sharing",
    "online-clipboard"
  ],
  "author": "Klipit Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.10.0",
    "dotenv": "^16.0.3",
    "uuid": "^9.0.0",
    "axios": "^1.4.0",
    "qrcode": "^1.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/cors": "^2.8.13",
    "@types/multer": "^1.4.7",
    "@types/uuid": "^9.0.2",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.40.0"
  }
}
